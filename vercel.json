{
  "version": 2,
  "functions": {
    "api/compile.js": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ],
  "env": {
    "JDOODLE_CLIENT_ID": "471db6e3a051d290e66025b1414a0c82",
    "JDOODLE_CLIENT_SECRET": "b5b224ef1aa53a75e968acef063a67ffa3512141f09a35d4fdec597794389dfe"
  }
}